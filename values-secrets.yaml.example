# ============================================================
# SECRETS CONFIGURATION
# ⚠️ NE PAS COMMITER CE FICHIER DANS GIT
# Ajouter à .gitignore
# ============================================================

# ============================================================
# DATABASE CREDENTIALS
# ============================================================
database:
  password: "devops_password"  # ← Remplacer par ton vrai mot de passe

# ============================================================
# JWT SECRET
# ============================================================
jwt:
  secret: "your-super-secret-jwt-key-change-this-in-production-2024"  # ← Générer un vrai secret

# ============================================================
# GITHUB CONTAINER REGISTRY (GHCR) - Public
# ============================================================
# Les images sont publiques sur GitHub Container Registry
# Pas besoin d'authentification pour les images publiques
#
# Images utilisées :
# - ghcr.io/yaraportfolio/auth-service:v3.3
# - ghcr.io/yaraportfolio/product-service:v3.3
# - ghcr.io/yaraportfolio/order-service:v3.3
# - ghcr.io/yaraportfolio/review-service:v3.3

# ============================================================
# NOTES
# ============================================================
# - Utilise GitHub Container Registry (GHCR) public
# - Pas d'authentification requise pour les images publiques
# - Voir values.yaml pour la configuration du registry
#
# Générer un secret JWT fort :
# openssl rand -base64 64 | tr -d '\n'
#
# Installation :
# helm install microservices . \
#   -f values.yaml \
#   -f values-secrets.yaml \
#   --set database.password=XXXXX \
#   --set jwt.secret=YYYYY